    },
    "Another season entry for this series is already in your library. Converting this season to a series can leave both the series and the sibling season entries in the library." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このシリーズの別シーズンの項目がすでにライブラリにあります。このシーズンをシリーズに変換すると、シリーズ項目と兄弟シーズン項目の両方がライブラリに残る可能性があります。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您的资料库中已存在该系列的其他季度条目。将此季度转换为系列后，资料库中可能会同时保留系列条目和其他同系列季度条目。"
          }
        }
      }
    },
