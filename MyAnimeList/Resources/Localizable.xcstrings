    "AniShelf can now show selected update notes after launch and reopen them later from Settings." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AniShelfは起動後に選択した更新ノートを表示し、あとから設定で再表示できるようになりました。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AniShelf现在可以在启动后显示选定的更新说明，也可以稍后从设置中重新打开。"
          }
        }
      }
    },
    "AniShelf could not prepare this export. Please try again." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AniShelfはこのエクスポートを準備できませんでした。もう一度お試しください。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AniShelf 无法准备此导出，请重试。"
          }
        }
      }
    },
    "AniShelf keeps watch status, dates, and quick notes together so your collection stays useful over time." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "視聴状況、日付、メモをまとめて管理し、コレクションを長く活用できます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "集中管理观看状态、日期，随手记录感想。"
          }
        }
      }
    },
    "AniShelf Library" : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
