    "Enter one title per line. Only the top TMDb TV series result and top movie result are shown, so precise titles work best." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1行に1タイトルずつ入力してください。各タイトルでは TMDb のTVシリーズと映画の最上位結果のみを表示するため、できるだけ正確なタイトルを入力してください。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "每行输入一个标题。每个标题只会显示 TMDb 排名最高的 TV 动画结果和电影结果，因此标题越准确越好。"
          }
        }
      }
    },
    "Enter Batch Add?" : {
      "localizations" : {
